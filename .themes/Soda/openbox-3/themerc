# Geometry
border.width: 1
menu.border.width: 1
menu.separator.width: 1
menu.separator.padding.width: 0
osd.border.width: 1
window.client.padding.width: 0
window.client.padding.height: 0
window.handle.width: 8
padding.width: 4
padding.height: 4
menu.overlap.x: -12
menu.overlap.y: 0

# Border colors
window.active.border.color: #c4cdf3
window.active.title.separator.color: #c4cdf3
window.inactive.border.color: #c4cdf3
window.inactive.title.separator.color: #c4cdf3
window.active.client.color: #ffffff
window.inactive.client.color: #ffffff
menu.border.color: #c4cdf3
osd.border.color: #c4cdf3

# Titlebar colors
window.active.label.text.color: #906e8b
window.inactive.label.text.color: #c4cdf3

window.active.button.*.bg: Gradient Vertical Solid
window.active.button.*.color: #ffffff
window.active.button.*.colorTo: #ffffff
window.active.button.*.unpressed.image.color: #7b6678
window.active.button.*.pressed.image.color: #dcbeca
window.active.button.*.disabled.image.color: #7b6678
window.active.button.*.hover.image.color: #dcbeca

window.inactive.button.*.bg: Gradient Vertical Solid
window.inactive.button.*.color: #ffffff
window.inactive.button.*.colorTo: #ffffff
window.inactive.button.*.unpressed.image.color: #7b6678
window.inactive.button.*.pressed.image.color: #dcbeca
window.inactive.button.*.disabled.image.color: #7b6678
window.inactive.button.*.hover.image.color: #dcbeca

# Active window textures
window.active.title.bg: Gradient Vertical Solid
window.active.title.bg.color: #e1efff
window.active.title.bg.colorTo: #e1efff
window.active.label.bg: Interlaced
window.active.label.bg.color: #e1efff
window.active.label.bg.interlace.color: #e1efff
window.active.handle.bg: Solid
window.active.handle.bg.color: #e1efff
window.active.grip.bg: Solid
window.active.grip.bg.color: #e1efff

# Inactive window textures
window.inactive.title.bg: Gradient Vertical Solid
window.inactive.title.bg.color: #e1efff
window.inactive.title.bg.colorTo: #e1efff
window.inactive.label.bg: Interlaced
window.inactive.label.bg.color: #e1efff
window.inactive.label.bg.interlace.color: #e1efff
window.inactive.handle.bg: Solid
window.inactive.handle.bg.color: #e1efff
window.inactive.grip.bg: Solid
window.inactive.grip.bg.color: #e1efff

# Active window button textures
window.*.active.button.*.bg: Parentrelative

# Inactive window button textures
window.*.inactive.button.*.bg: Parentrelative

# Menu colors
menu.title.text.color: #c4cdf3
menu.items.text.color: #7b6678
menu.items.disabled.text.color: #dcbeca
menu.items.active.text.color: #7b6678
menu.items.active.disabled.text.color: #7b6678
menu.separator.color: #c4cdf3

# Menu textures
menu.items.bg: Flat
menu.items.bg.color: #ffffff
menu.items.active.bg: Solid
menu.items.active.bg.color: #e1efff
menu.title.bg: Horizontal Gradient Solid
menu.title.bg.color: #e1efff
menu.title.bg.colorTo: #ffffff

# OSD textures
osd.label.text.color: #7b6678
osd.bg: Solid
osd.bg.color: #ffffff
osd.bg.colorTo: #ffffff
osd.label.bg: Parentrelative
osd.hilight.bg: Flat
osd.hilight.bg.color: #7b6678
osd.unhilight.bg: Flat
osd.unhilight.bg.color: #ffffff

# Text justification
window.label.text.justify: Center
menu.title.text.justify: Center

